# ============================================================
# VoxeraMeta v2.0 — Tamamen ÜCRETSİZ API Yapılandırması
# cp .env.example .env → değerleri doldur
# ============================================================

PORT=3000
NODE_ENV=production

# Android ↔ Backend güvenlik tokeni (kendin belirle)
# Üretmek için: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
API_AUTH_TOKEN=BURAYA_KENDI_TOKENINI_KOY

# ── 1. GROQ — TAMAMEN ÜCRETSİZ ──────────────────────────────
# Kayıt: https://console.groq.com → API Keys → Create
# Ücretsiz limit: llama-3.3-70b → 1.000 istek/gün, 14.400 istek/gün (8b model)
# Kredi kartı GEREKMİYOR
# Format: gsk_XXXXXXXXXXXXXXXXXXXX
GROQ_API_KEY=gsk_BURAYA_KOY

# ── 2. OPENROUTER — ÜCRETSİZ MODELLER ──────────────────────
# Kayıt: https://openrouter.ai → Sign in → API Keys
# Ücretsiz limit: 200 istek/gün (":free" modeller)
# Kredi kartı GEREKMİYOR
# Format: sk-or-v1-XXXXXXXXXXXXXXXXXXXX
OPENROUTER_API_KEY=sk-or-v1-BURAYA_KOY

# ── 3. GOOGLE GEMINI — ÜCRETSİZ ─────────────────────────────
# Kayıt: https://aistudio.google.com → Get API Key
# Ücretsiz limit: gemini-2.5-flash → 10 istek/dk, 500 istek/gün
# Kredi kartı GEREKMİYOR
# Format: AIzaSyXXXXXXXXXXXXXXXXXX
GEMINI_API_KEY=AIzaSy_BURAYA_KOY

# ── 4. HUGGINGFACE — ÜCRETSİZ MÜZİK ÜRETİMİ (1. ÖNCELİK) ──
# Kayıt: https://huggingface.co → Settings → Access Tokens
# Ücretsiz: musicgen-small / musicgen-medium modeli (rate limit var)
# Kredi kartı GEREKMİYOR
# Format: hf_XXXXXXXXXXXXXXXXXXXX
HUGGINGFACE_API_KEY=hf_BURAYA_KOY

# ── 5. STABILITY AI — STABLE AUDIO FALLBACK (OPSİYONEL) ────
# Kayıt: https://platform.stability.ai → API Keys
# Ücretsiz limit: 25 kredi/gün (stable-audio-2.0 için ~25 şarkı/gün)
# HuggingFace rate limit'e düşünce otomatik devreye girer
# Kredi kartı GEREKMİYOR (ücretsiz tier için)
# Format: sk-XXXXXXXXXXXXXXXXXXXX
STABILITY_AI_API_KEY=sk-BURAYA_KOY

# ── DEPOLAMA ─────────────────────────────────────────────────
LOCAL_STORAGE_PATH=/tmp/voxerameta-songs
MAX_REQUESTS_PER_MINUTE=20
BASE_URL=https://SENIN-APP-ADIN.onrender.com
